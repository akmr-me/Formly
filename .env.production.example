COMPOSE_PROJECT_NAME=formly
APP_ENV_FILE=.env.production
DOMAIN=formly.example.com
APP_URL=https://formly.example.com

POSTGRES_USER=formly_user
POSTGRES_PASSWORD=change_me_to_a_long_random_password
POSTGRES_DB=formly_db
DATABASE_URL=postgresql://formly_user:change_me_to_a_long_random_password@postgres:5432/formly_db

SERVER_HOST=127.0.0.1
SERVER_PORT=8000
CLIENT_HOST=127.0.0.1
CLIENT_PORT=3000

NODE_ENV=production
PORT=8000
CORS_ORIGIN=https://formly.example.com
ASSETS_BASE_URL=https://formly.example.com
JWT_SECRET=test
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_ASSETS_BASE_URL=https://formly.example.com
